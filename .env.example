# لایه ۵ (مهندسی پرامپت) به یک مدل هوش مصنوعی نیاز دارد. سه حالت:
#
# الف) OpenRouter (مدل رایگان) — اولویت اول. کلید را از openrouter.ai/keys بگیر.
OPENROUTER_API_KEY=
# مدل پیش‌فرض؛ در صورت تمایل عوض کن (مثلاً moonshotai/kimi-k2.6:free)
OPENROUTER_MODEL=google/gemma-4-31b-it:free
#
# ب) Claude — اگر کلید OpenRouter نبود ولی این تنظیم شده باشد استفاده می‌شود.
ANTHROPIC_API_KEY=
#
# ج) اگر هیچ‌کدام تنظیم نشوند، بازی در «حالت آفلاین» با ارزیاب لوکال کار می‌کند.

# (اختیاری — برای توسعه‌ی آینده) متغیرهای Supabase برای لیدربورد سراسری.
# بازی بدون این‌ها کاملاً کار می‌کند.
# NEXT_PUBLIC_SUPABASE_URL=
# NEXT_PUBLIC_SUPABASE_ANON_KEY=
